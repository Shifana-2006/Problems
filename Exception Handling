/*Exception-To handle runtime error*/ 

/* Checked Exception - when we know the error at the compile time
Unchecked Exception - when we know the error at the run time */

Compile time error → before running (syntax mistake)
Runtime error → while running (program stops unexpectedly)

/*Compile time error -  like missing semicolon 
run time error :
try block - for critical statement
catch block - immediate after try block ,it executes(when try block has error otherwise not)
finally - executes always(whether error occurs or not) [use for file close,release,open]
throw - manually creates
throws - method may give an exception to the caller.
*/


//try & catch
import java.util.*;

public class Main
{
	public static void main(String[] args) {
	    Scanner sc=new Scanner(System.in);
		  try{
		  int a=sc.nextInt(); //if i enter string 
		  }
		  catch(Exception e){
		      System.out.print(e);
		  }
	}
}

//try & catch & finally

import java.util.*;

public class Main
{
	public static void main(String[] args) {
	    Scanner sc=new Scanner(System.in);
		  try{
		  int a=10/0;
		  }
		  catch(ArithmeticException e){
		      System.out.println("Exception : " +e);
		  }
		  
		  finally{
		      System.out.println("Program never stops!!");
		  }
		 
	}
}

//throw

import java.util.*;

public class Main
{
	public static void main(String[] args) {
	    Scanner sc=new Scanner(System.in);
		  try{
		  int age=sc.nextInt();
		  if(age<1){
		      throw new Exception("Age must be greater than 1");
		  }
		  
		  }
		  catch(Exception e){
		      System.out.println(e);
		  }
		  
		 System.out.print("Program Ended");
	}
}
