        }
    }
}

//Custom Exception Handling

import java.util.*;

class NotValidException extends Exception {
    NotValidException(String s) {
        super(s);//stored string message pass to the parentcls
    }
}

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        try {
            int age = sc.nextInt();

            if (age < 18) {
                throw new NotValidException("Your Age should be greater than 18");
            }
            
        } catch (NotValidException e) {
            System.out.println(e.getMessage());
        }
//we can also create another standard catch cls to display the other errors
    }
}
