//try & catch & finally

import java.util.*;

public class Main
{
	public static void main(String[] args) {
	    Scanner sc=new Scanner(System.in);
		  try{
		  int a=10/0;
		  }
		  catch(ArithmeticException e){
		      System.out.println("Exception : " +e);
		  }
		  
		  finally{
		      System.out.println("Program never stops!!");
		  }
		 
	}
}

