//optimised method to print duplicate
import java.util.*;
class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int[] arr=new int[n];
        for(int i=0;i<n;i++){
            arr[i]=sc.nextInt();
        }
        
      HashSet<Integer> set=new HashSet<>();
      for(int num:arr){
          if(set.contains(num)){ //duplicates
              System.out.print(num+" ");
          }
          else{
              set.add(num); //non duplicates
          }
      }
}
}


