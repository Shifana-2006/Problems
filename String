//1.reverse entire string(method-1)
//"hello world" - "dlrow olleh"
import java.util.*;
public class Main{
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        String str=sc.nextLine();
        
            for(int i=str.length()-1;i>=0;i--){
                System.out.print(str.charAt(i));
            }
       
           
    }
}

//reverse each word in a string(method-2)
//"hello world" - "olleh dlrow"
import java.util.*;
public class Main{
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        String str=sc.nextLine();
        String arr[]=str.split(" ");
        
        for(int i=0;i<arr.length;i++){
            String currentword=arr[i];
            for(int j=currentword.length()-1;j>=0;j--){
                System.out.print(currentword.charAt(j));
            }
        
        System.out.print(" ");
        }
           
    }
}

//reverse order of the word
//"hello world" - "world hello"
import java.util.*;
public class Main{
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        String str=sc.nextLine();
        String arr[]=str.split(" ");
        
        for(int i=arr.length-1;i>=0;i--){
            System.out.print(arr[i]+" ");
        }
           
    }
}

//2.Check plaindrome or not
import java.util.*;
public class Main{
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        String str=sc.nextLine();
        String rev="";
        
            for(int i=str.length()-1;i>=0;i--){
               rev=rev+str.charAt(i);
            }
       
       if(str.equals(rev))
         System.out.print("Palindrome String");
         else
         System.out.print("Not Palindrome String");
    
           
    }
}
